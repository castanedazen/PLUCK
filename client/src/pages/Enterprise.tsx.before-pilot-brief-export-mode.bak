    ],
    hotspots: [
      { label: 'Pasadena demand pocket', top: '28%', left: '68%' },
      { label: 'Citrus seller cluster', top: '44%', left: '58%' },
      { label: 'High-confidence pickup zone', top: '62%', left: '72%' },
    ],
    demandSignals: [
