  border-radius:999px;
  display:grid;
  place-items:center;
  background:#102033;
  color:#fff;
  font-weight:700;
}

.enterprise-check-row p{
  margin:2px 0 0;
  color:#22374d;
  font-weight:600;
}

.enterprise-risk-stack{
  display:grid;
  gap:12px;
}

.enterprise-risk-card{
  padding:16px;
  border-radius:18px;
  background:linear-gradient(180deg, #fffaf2 0%, #fff 100%);
  border:1px solid rgba(214,224,236,0.95);
}

.enterprise-risk-top{
  display:flex;
  justify-content:space-between;
  gap:12px;
  align-items:center;
  margin-bottom:8px;
}

.enterprise-risk-top strong{
  color:#102033;
}

.enterprise-risk-top span{
  padding:6px 10px;
  border-radius:999px;
  background:#102033;
  color:#fff;
  font-size:.78rem;
  font-weight:700;
}

.enterprise-table-wrap{
  overflow:auto;
  border-radius:18px;
  border:1px solid rgba(214,224,236,0.95);
}

.enterprise-table{
  width:100%;
  border-collapse:collapse;
  min-width:720px;
  background:#fff;
}

.enterprise-table th,
.enterprise-table td{
  text-align:left;
  padding:14px 16px;
  border-bottom:1px solid rgba(232,238,244,0.95);
}

.enterprise-table th{
  background:#f8fbff;
  color:#5d6f86;
  font-size:.84rem;
  text-transform:uppercase;
  letter-spacing:.14em;
}

.enterprise-cta-card{
  display:grid;
  grid-template-columns:1.2fr auto;
  gap:18px;
  align-items:center;
  padding:24px 26px;
}

.investor-cta{
  background:linear-gradient(180deg, #ffffff 0%, #f7fafc 100%);
}

.enterprise-cta-card h2{
  margin:6px 0 10px;
  font-size:2rem;
  line-height:1.02;
  letter-spacing:-.03em;
}

.enterprise-cta-row,
.enterprise-cta-actions{
  display:flex;
  flex-wrap:wrap;
  gap:12px;
  margin-top:22px;
}

@media (max-width: 1100px){
  .enterprise-diligence-topbar,
  .enterprise-diligence-hero,
  .enterprise-control-row,
  .enterprise-three-col,
  .enterprise-cta-card{
    grid-template-columns:1fr;
    flex-direction:column;
    align-items:start;
  }

  .enterprise-tab-head{
    flex-direction:column;
    align-items:start;
  }

  .enterprise-investor-copy h1{
    font-size:2.6rem;
  }
}


/* ENTERPRISE DASHBOARD V10 */
.enterprise-dashboard.v10{
  display:grid;
  gap:22px;
}

.enterprise-dataroom-topbar{
  display:flex;
  justify-content:space-between;
  gap:18px;
  align-items:center;
  padding:16px 18px;
}

.enterprise-dataroom-hero{
  display:grid;
  grid-template-columns:1.15fr .85fr;
  gap:22px;
  align-items:center;
  padding:30px;
  border-radius:30px;
  background:linear-gradient(180deg, #ffffff 0%, #f7fafc 100%);
}

.enterprise-dataroom-card{
  padding:24px;
  border-radius:24px;
  background:linear-gradient(180deg, #f8fbff 0%, #eef4fb 100%);
  border:1px solid rgba(214,224,236,0.95);
  box-shadow:0 10px 24px rgba(16,32,51,.05);
}

.enterprise-dataroom-card span{
  display:block;
