@media print{
  .enterprise-flagship-topbar .enterprise-investor-actions,
  .enterprise-control-row,
  .flagship-tabs{
    display:none !important;
  }

  .enterprise-dashboard.presentation-export-mode{
    gap:18px;
  }

  .section-card,
  .flagship-panel,
  .flagship-map-panel,
  .enterprise-cta-card.flagship-cta{
    box-shadow:none !important;
    break-inside:avoid;
  }
}

@media (max-width: 1100px){
  .enterprise-flagship-topbar,
  .enterprise-flagship-hero,
  .enterprise-control-row,
  .enterprise-three-col,
  .enterprise-two-col,
  .enterprise-cta-card.flagship-cta,
  .enterprise-kpi-grid.flagship{
    grid-template-columns:1fr;
    flex-direction:column;
    align-items:start;
  }

  .enterprise-tab-head{
    flex-direction:column;
    align-items:start;
  }

  .enterprise-flagship-copy h1{
    font-size:2.7rem;
  }

  .flagship-map-mock{
    min-height:320px;
  }
}


/* CONSUMER FLAGSHIP POLISH */

/* overall page rhythm */
.route-shell,
.stack,
.stack-list{
  gap:22px !important;
}

/* section cards: cleaner premium look */
.section-card{
  border-radius:24px !important;
  border:1px solid rgba(214,224,236,0.92) !important;
  box-shadow:0 10px 24px rgba(16,32,51,0.05) !important;
  background:linear-gradient(180deg, #ffffff 0%, #fbfdff 100%) !important;
}

/* top hero / live orchard cards */
.hero-live-grid__cards{
  display:grid !important;
  grid-template-columns:repeat(4,minmax(0,1fr)) !important;
  gap:18px !important;
}

.hero-live-card{
  border-radius:24px !important;
  overflow:hidden !important;
  min-height:auto !important;
  background:#fff !important;
  box-shadow:0 12px 26px rgba(16,32,51,0.07) !important;
  border:1px solid rgba(214,224,236,0.92) !important;
  transition:transform .18s ease, box-shadow .18s ease !important;
}

.hero-live-card:hover{
  transform:translateY(-2px) !important;
  box-shadow:0 18px 32px rgba(16,32,51,0.10) !important;
}

.hero-live-card > img,
.hero-live-card img{
  width:100% !important;
  height:168px !important;
  min-height:168px !important;
  max-height:168px !important;
  object-fit:cover !important;
  display:block !important;
}

/* trust / overlay pills */
.hero-live-card .trust-strip,
.hero-live-card__overlay .trust-strip{
  display:flex !important;
  flex-wrap:wrap !important;
  gap:8px !important;
}

.hero-live-card .trust-mini,
.hero-live-card__overlay .trust-mini,
.hero-live-card .trust-pill,
.hero-live-card__overlay .trust-pill,
.pill,
.badge,
.tag,
.chip,
.listing-badge{
  background:rgba(255,255,255,0.94) !important;
  color:#102033 !important;
  border:1px solid rgba(214,224,236,0.95) !important;
  box-shadow:0 4px 12px rgba(16,32,51,0.04) !important;
}

/* make pill text stronger */
.pill,
.badge,
.tag,
.chip,
.listing-badge,
[class*="pill"],
[class*="badge"],
[class*="tag"]{
  color:#102033 !important;
  font-weight:600 !important;
}

/* just added / mini listing cards */
.mini-grid{
  display:grid !important;
  grid-template-columns:repeat(3,minmax(0,1fr)) !important;
  gap:16px !important;
}

.activity-card,
.activity-card--live{
  border-radius:22px !important;
  border:1px solid rgba(214,224,236,0.92) !important;
  background:linear-gradient(180deg, #ffffff 0%, #fbfdff 100%) !important;
  box-shadow:0 8px 18px rgba(16,32,51,0.05) !important;
  padding:14px !important;
}

.activity-card--live img,
.mini-grid .activity-card img{
  width:96px !important;
  min-width:96px !important;
  max-width:96px !important;
  height:96px !important;
  min-height:96px !important;
  max-height:96px !important;
  object-fit:cover !important;
  border-radius:16px !important;
}

/* harvest feed / grower cards */
.social-grid{
  display:grid !important;
  grid-template-columns:repeat(3,minmax(0,1fr)) !important;
  gap:18px !important;
}

.social-card{
  border-radius:24px !important;
  overflow:hidden !important;
  border:1px solid rgba(214,224,236,0.92) !important;
  background:#fff !important;
  box-shadow:0 10px 22px rgba(16,32,51,0.05) !important;
}

.social-image{
  width:100% !important;
  height:220px !important;
  min-height:220px !important;
  max-height:220px !important;
  object-fit:cover !important;
  display:block !important;
}

/* buttons */
button.primary,
.primary{
  border-radius:999px !important;
  box-shadow:0 10px 18px rgba(16,32,51,0.10) !important;
}

button.ghost,
.ghost{
  border-radius:999px !important;
  border:1px solid rgba(214,224,236,0.95) !important;
  background:rgba(255,255,255,0.96) !important;
  color:#102033 !important;
}

/* headings / section rhythm */
.section-heading h2,
.compact-heading h2{
  letter-spacing:-0.035em !important;
  line-height:1.02 !important;
}

.eyebrow{
  letter-spacing:0.14em !important;
}

/* table / summary areas */
.enterprise-signal-summary-row,
.enterprise-table th,
.enterprise-table td{
  border-color:rgba(232,238,244,0.95) !important;
}

/* mobile / tablet */
@media (max-width: 1100px){
  .hero-live-grid__cards{
    grid-template-columns:repeat(2,minmax(0,1fr)) !important;
  }

  .mini-grid,
  .social-grid{
    grid-template-columns:1fr !important;
  }
}

@media (max-width: 720px){
  .hero-live-grid__cards{
    grid-template-columns:1fr !important;
  }

  .hero-live-card > img,
  .hero-live-card img{
    height:188px !important;
    min-height:188px !important;
    max-height:188px !important;
  }

  .section-card{
    border-radius:20px !important;
  }

  .activity-card--live img,
  .mini-grid .activity-card img{
    width:84px !important;
    min-width:84px !important;
    max-width:84px !important;
    height:84px !important;
    min-height:84px !important;
    max-height:84px !important;
  }
}
