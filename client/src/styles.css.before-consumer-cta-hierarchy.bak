  color:#102033;
  font:600 15px/1 Inter, Arial, sans-serif;
}

.enterprise-tab-row{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  margin-bottom:18px;
}

.enterprise-tab{
  appearance:none;
  border:1px solid rgba(214,224,236,0.95);
  background:#fff;
  color:#102033;
  border-radius:999px;
  padding:10px 16px;
  font-weight:600;
