}

.enterprise-tab-head{
  display:flex;
  justify-content:space-between;
  gap:16px;
  align-items:end;
  margin-bottom:18px;
}

.enterprise-panel-stack{
  display:grid;
  gap:20px;
}

.enterprise-three-col{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:18px;
}

.enterprise-panel{
  padding:24px;
}

.flagship-panel{
  border-radius:26px;
  box-shadow:0 10px 24px rgba(16,32,51,.04);
}

.enterprise-panel-head{
  margin-bottom:18px;
}

.enterprise-panel-head h3,
.enterprise-panel h3{
  margin:6px 0 0;
  color:#102033;
}

.enterprise-takeaway-list{
  display:grid;
  gap:14px;
}

.enterprise-takeaway-card{
  display:grid;
  grid-template-columns:auto 1fr;
  gap:12px;
  align-items:start;
  padding:16px 18px;
  border-radius:18px;
  background:linear-gradient(180deg, #f8fbff 0%, #eef4fb 100%);
  border:1px solid rgba(214,224,236,0.95);
}

.enterprise-takeaway-card span{
  font-size:1.2rem;
  color:#d28a2f;
  line-height:1;
  margin-top:2px;
}

.enterprise-takeaway-card p{
  margin:0;
  color:#22374d;
  font-weight:600;
}

.enterprise-signal-summary{
  display:grid;
  gap:12px;
}

.enterprise-signal-summary-row{
  display:flex;
  justify-content:space-between;
  gap:16px;
  align-items:center;
  padding:14px 16px;
  border-radius:16px;
  border:1px solid rgba(214,224,236,0.95);
  background:#f9fbfd;
}

.enterprise-signal-summary-row span{
  color:#607288;
  font-weight:600;
}

.enterprise-signal-summary-row strong{
  color:#102033;
  text-align:right;
}

.enterprise-table-wrap{
  overflow:auto;
  border-radius:18px;
  border:1px solid rgba(214,224,236,0.95);
}

.enterprise-table{
  width:100%;
  border-collapse:collapse;
  min-width:720px;
  background:#fff;
}

.enterprise-table th,
.enterprise-table td{
  text-align:left;
  padding:14px 16px;
  border-bottom:1px solid rgba(232,238,244,0.95);
}

.enterprise-table th{
  background:#f8fbff;
  color:#5d6f86;
  font-size:.84rem;
  text-transform:uppercase;
  letter-spacing:.14em;
}

.enterprise-decision-card{
  padding:22px 24px;
  border-radius:22px;
  background:linear-gradient(180deg, #fffaf2 0%, #fff3dd 100%);
  border:1px solid rgba(214,224,236,0.95);
}

.flagship-decision strong{
  display:block;
  margin-bottom:10px;
  color:#8a5a13;
  font-size:1rem;
}

.flagship-decision p{
  margin:0;
  color:#213448;
  font-weight:600;
  line-height:1.55;
}

.enterprise-cta-card.flagship-cta{
  display:grid;
  grid-template-columns:1.2fr auto;
  gap:18px;
  align-items:center;
  padding:26px 28px;
  border-radius:28px;
  background:linear-gradient(180deg, #ffffff 0%, #f7fafc 100%);
}

.enterprise-cta-card h2{
  margin:6px 0 10px;
  font-size:2rem;
  line-height:1.02;
  letter-spacing:-.03em;
}

.enterprise-cta-row,
.enterprise-cta-actions{
  display:flex;
  flex-wrap:wrap;
  gap:12px;
  margin-top:22px;
}

@media (max-width: 1100px){
  .enterprise-flagship-topbar,
  .enterprise-flagship-hero,
  .enterprise-control-row,
  .enterprise-three-col,
  .enterprise-cta-card.flagship-cta,
  .enterprise-kpi-grid.flagship{
    grid-template-columns:1fr;
    flex-direction:column;
    align-items:start;
  }

  .enterprise-tab-head{
    flex-direction:column;
    align-items:start;
  }

  .enterprise-flagship-copy h1{
    font-size:2.7rem;
  }
}


/* PRESENTATION EXPORT MODE */
.enterprise-dashboard.presentation-mode,
.enterprise-dashboard.presentation-export-mode{
  display:grid;
  gap:24px;
}

.presentation-export-mode{
  gap:30px;
}

.enterprise-flagship-topbar{
  display:flex;
  justify-content:space-between;
  gap:18px;
  align-items:center;
  padding:16px 18px;
}

.enterprise-investor-actions{
  display:flex;
  flex-wrap:wrap;
  gap:12px;
}

.active-presentation-toggle{
  border-color:#102033 !important;
  background:#102033 !important;
  color:#fff !important;
}

.enterprise-flagship-hero{
  display:grid;
  grid-template-columns:1.15fr .85fr;
  gap:22px;
  align-items:center;
  padding:32px;
  border-radius:32px;
  background:linear-gradient(180deg, #ffffff 0%, #f7fafc 100%);
  box-shadow:0 18px 44px rgba(16,32,51,.06);
}

.enterprise-flagship-copy h1{
  margin:0 0 14px;
  font-size:clamp(2.5rem, 4.6vw, 5.2rem);
  line-height:.93;
  letter-spacing:-.055em;
  color:#102033;
}

.enterprise-subcopy.dark{
  max-width:740px;
  color:#44566c;
}

.enterprise-flagship-thesis{
  padding:26px;
  border-radius:26px;
  background:linear-gradient(180deg, #fffaf2 0%, #fff3dd 100%);
  border:1px solid rgba(214,224,236,0.95);
  box-shadow:0 10px 24px rgba(16,32,51,.05);
}

.enterprise-flagship-thesis span{
  display:block;
  margin-bottom:10px;
  font-size:.8rem;
  text-transform:uppercase;
  letter-spacing:.15em;
  color:#8a5a13;
  font-weight:700;
}

.enterprise-flagship-thesis strong{
  font-size:1.34rem;
  line-height:1.3;
  color:#213448;
}

.enterprise-kpi-grid.flagship{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:18px;
}

.enterprise-kpi-card{
  padding:22px 24px;
}

.enterprise-kpi-value{
  margin:0;
  font-size:2.1rem;
  line-height:1;
  font-weight:700;
  color:#102033;
}

.enterprise-kpi-label{
  margin:8px 0 0;
  color:#5c708a;
  font-weight:600;
}

.flagship-map-panel{
  padding:24px;
  border-radius:28px;
}

.flagship-map-layout{
  margin-top:10px;
}

.flagship-map-mock{
  min-height:400px;
}

.enterprise-map-mock{
  position:relative;
  border-radius:24px;
  overflow:hidden;
  border:1px solid rgba(214,224,236,0.95);
  background:
    radial-gradient(circle at 20% 20%, rgba(255,194,92,.22), transparent 18%),
    radial-gradient(circle at 72% 26%, rgba(236,115,87,.20), transparent 20%),
    radial-gradient(circle at 66% 70%, rgba(49,125,255,.14), transparent 18%),
    linear-gradient(180deg, #f7fbff 0%, #edf3f9 100%);
}

.enterprise-map-dot{
  position:absolute;
  width:18px;
  height:18px;
  border-radius:50%;
  background:#d28a2f;
  box-shadow:0 0 0 8px rgba(210,138,47,.14);
}

.enterprise-map-dot.dot-a{ top:22%; left:26%; }
.enterprise-map-dot.dot-b{ top:38%; left:64%; }
.enterprise-map-dot.dot-c{ top:62%; left:44%; }
.enterprise-map-dot.dot-d{ top:71%; left:76%; }

.enterprise-map-ring{
  position:absolute;
  border-radius:999px;
  border:2px dashed rgba(92,112,138,.28);
}

.enterprise-map-ring.ring-a{ inset:18% 18% 42% 24%; }
.enterprise-map-ring.ring-b{ inset:36% 28% 18% 38%; }
.enterprise-map-ring.ring-c{ inset:16% 40% 46% 10%; }

.enterprise-map-label{
  position:absolute;
  padding:8px 10px;
  border-radius:999px;
  background:rgba(255,255,255,.92);
  border:1px solid rgba(214,224,236,0.95);
  color:#213448;
  font-size:.84rem;
  font-weight:600;
}

.enterprise-map-label.label-a{ top:18%; left:10%; }
.enterprise-map-label.label-b{ top:32%; right:10%; }
.enterprise-map-label.label-c{ bottom:22%; left:22%; }

.flagship-side-metrics{
  display:grid;
  gap:12px;
  align-content:start;
}

.flagship-shell{
  padding:22px;
}

.enterprise-control-row{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:14px;
  margin-bottom:18px;
}

.enterprise-select-group{
  display:grid;
  gap:8px;
}

.enterprise-select-group label{
  font-size:.78rem;
  text-transform:uppercase;
  letter-spacing:.16em;
  font-weight:700;
  color:#6b7d93;
}

.enterprise-select-group select{
  width:100%;
  border-radius:14px;
  border:1px solid rgba(214,224,236,0.95);
  background:#fff;
  padding:12px 14px;
  color:#102033;
  font:600 15px/1 Inter, Arial, sans-serif;
}

.flagship-tabs{
  margin-bottom:20px;
}

.enterprise-tab-row{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
}

.enterprise-tab{
  appearance:none;
  border:1px solid rgba(214,224,236,0.95);
  background:#fff;
  color:#102033;
  border-radius:999px;
  padding:10px 16px;
  font-weight:600;
  cursor:pointer;
}

.enterprise-tab.active{
  background:#102033;
  color:#fff;
  border-color:#102033;
}

.enterprise-tab-head{
  display:flex;
  justify-content:space-between;
  gap:16px;
  align-items:end;
  margin-bottom:18px;
}

.enterprise-panel-stack{
  display:grid;
  gap:20px;
}

.presentation-slides{
  gap:22px;
}

.enterprise-two-col{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:18px;
}

.enterprise-three-col{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
