.enterprise-cta-row,
.enterprise-cta-actions{
  display:flex;
  flex-wrap:wrap;
  gap:12px;
  margin-top:22px;
}

.enterprise-kpi-grid{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:16px;
}

.enterprise-kpi-card{
  padding:20px 22px;
}

.enterprise-kpi-value{
  margin:0;
  font-size:2rem;
  line-height:1;
  font-weight:700;
  color:#102033;
}

.enterprise-kpi-label{
  margin:8px 0 0;
  color:#5c708a;
  font-weight:600;
}

.enterprise-tabs-shell{
  padding:20px;
}

.enterprise-tab-row{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  margin-bottom:14px;
}

.enterprise-tab{
  appearance:none;
  border:1px solid rgba(214,224,236,0.95);
  background:#fff;
  color:#102033;
  border-radius:999px;
  padding:10px 16px;
  font-weight:600;
  cursor:pointer;
}

.enterprise-tab.active{
  background:#102033;
  color:#fff;
  border-color:#102033;
}

.enterprise-filter-row{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  margin-bottom:18px;
}

.enterprise-filter{
  appearance:none;
  border:1px solid rgba(214,224,236,0.95);
  background:linear-gradient(180deg, #fffaf2 0%, #fff3dd 100%);
  color:#102033;
  border-radius:999px;
  padding:8px 14px;
  font-weight:600;
  cursor:pointer;
}

.enterprise-filter.active{
  background:#102033;
  color:#fff;
  border-color:#102033;
}

.enterprise-tab-head{
  display:flex;
  justify-content:space-between;
  gap:16px;
  align-items:end;
  margin-bottom:16px;
}

.enterprise-panel-stack{
  display:grid;
  gap:18px;
}

.enterprise-two-col{
  display:grid;
  grid-template-columns:1.15fr .85fr;
  gap:18px;
}

.enterprise-three-col{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:18px;
}

.enterprise-panel{
  padding:22px;
}

.enterprise-panel-head{
  margin-bottom:18px;
}

.enterprise-panel-head h3{
  margin:6px 0 0;
  font-size:1.45rem;
  line-height:1.06;
  letter-spacing:-.03em;
}

.enterprise-signal-grid{
  display:grid;
  grid-template-columns:repeat(2,minmax(0,1fr));
  gap:14px;
}

.enterprise-signal-grid-wide{
  grid-template-columns:repeat(2,minmax(0,1fr));
}

.enterprise-signal-card{
  padding:16px;
  border-radius:20px;
  background:linear-gradient(180deg, #f8fbff 0%, #eef4fb 100%);
  border:1px solid rgba(214,224,236,0.95);
}

.enterprise-signal-card h3,
.enterprise-demand-card h3,
.enterprise-flow-step h3,
.enterprise-panel h3{
  margin:0 0 6px;
  color:#102033;
}

.enterprise-signal-label{
  margin:0 0 8px;
  font-size:.76rem;
  text-transform:uppercase;
  letter-spacing:.18em;
  color:#6e7f97;
  font-weight:700;
}

.enterprise-map-mock{
  position:relative;
  min-height:380px;
  border-radius:24px;
  overflow:hidden;
  border:1px solid rgba(214,224,236,0.95);
  background:
    radial-gradient(circle at 20% 20%, rgba(255,194,92,.22), transparent 18%),
    radial-gradient(circle at 72% 26%, rgba(236,115,87,.20), transparent 20%),
    radial-gradient(circle at 66% 70%, rgba(49,125,255,.14), transparent 18%),
    linear-gradient(180deg, #f7fbff 0%, #edf3f9 100%);
}

.enterprise-map-dot{
  position:absolute;
  width:18px;
  height:18px;
  border-radius:50%;
  background:#d28a2f;
  box-shadow:0 0 0 8px rgba(210,138,47,.14);
}

.enterprise-map-dot.dot-a{ top:22%; left:26%; }
.enterprise-map-dot.dot-b{ top:38%; left:64%; }
.enterprise-map-dot.dot-c{ top:62%; left:44%; }
.enterprise-map-dot.dot-d{ top:71%; left:76%; }

.enterprise-map-ring{
  position:absolute;
  border-radius:999px;
  border:2px dashed rgba(92,112,138,.28);
}

.enterprise-map-ring.ring-a{ inset:18% 18% 42% 24%; }
.enterprise-map-ring.ring-b{ inset:36% 28% 18% 38%; }
.enterprise-map-ring.ring-c{ inset:16% 40% 46% 10%; }

.enterprise-map-label{
  position:absolute;
  padding:8px 10px;
  border-radius:999px;
  background:rgba(255,255,255,.92);
  border:1px solid rgba(214,224,236,0.95);
  color:#213448;
  font-size:.84rem;
  font-weight:600;
}

.enterprise-map-label.label-a{ top:18%; left:10%; }
.enterprise-map-label.label-b{ top:32%; right:10%; }
.enterprise-map-label.label-c{ bottom:22%; left:22%; }

.enterprise-map-legend{
  position:absolute;
  left:16px;
  right:16px;
  bottom:16px;
  display:grid;
  gap:8px;
  padding:14px 16px;
  border-radius:18px;
  background:rgba(255,255,255,.92);
  border:1px solid rgba(214,224,236,0.95);
  font-size:.92rem;
  color:#44566c;
}

.enterprise-bar-chart{
  display:grid;
  gap:14px;
}

.enterprise-bar-group{
  display:grid;
  gap:6px;
}

.enterprise-bar-label{
  font-weight:700;
  color:#213448;
}

.enterprise-bar-track{
  width:100%;
  height:10px;
  border-radius:999px;
  background:#edf3f8;
  overflow:hidden;
}

.enterprise-bar{
  height:100%;
  border-radius:999px;
}

.enterprise-bar.supply{
  background:#d69a3a;
}

.enterprise-bar.demand{
  background:#5d86c7;
}

.enterprise-legend-row{
  display:flex;
  gap:14px;
  margin-top:14px;
  color:#596b81;
  font-size:.92rem;
}

.swatch{
  width:12px;
  height:12px;
  display:inline-block;
  border-radius:999px;
  margin-right:6px;
}

.swatch.supply{ background:#d69a3a; }
.swatch.demand{ background:#5d86c7; }

.enterprise-sparkline-shell{
  display:grid;
  gap:10px;
}

.enterprise-sparkline{
  width:100%;
  height:160px;
  color:#d28a2f;
  background:linear-gradient(180deg, #fffaf2 0%, #fff 100%);
  border-radius:18px;
  border:1px solid rgba(214,224,236,0.95);
  padding:8px;
}

.enterprise-sparkline-labels{
  display:flex;
  justify-content:space-between;
  color:#728197;
  font-size:.88rem;
}

.enterprise-insight-strip{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:12px;
}

.enterprise-insight-strip.compact{
  grid-template-columns:1fr;
}

.enterprise-insight-pill{
  display:flex;
  flex-direction:column;
  gap:6px;
  padding:16px 18px;
  border-radius:18px;
  border:1px solid rgba(214,224,236,0.95);
  background:#fff;
}

.enterprise-insight-pill span{
  font-size:.74rem;
  text-transform:uppercase;
  letter-spacing:.16em;
  color:#6f7f95;
  font-weight:700;
}

.enterprise-insight-pill strong{
  font-size:1.08rem;
  line-height:1.1;
  color:#102033;
}

.enterprise-insight-pill.tone-gold{
  background:linear-gradient(180deg, #fffaf2 0%, #fff3dd 100%);
}

.enterprise-insight-pill.tone-blue{
  background:linear-gradient(180deg, #f6fbff 0%, #eaf3fd 100%);
}

.enterprise-insight-pill.tone-slate{
  background:linear-gradient(180deg, #f8fafc 0%, #eef3f8 100%);
}

.enterprise-demand-stack,
.enterprise-flow{
  display:grid;
  gap:14px;
}

.enterprise-demand-card{
  padding:16px;
  border-radius:18px;
  border:1px solid rgba(214,224,236,0.95);
  background:#f9fbfd;
}

.enterprise-flow-step{
  display:grid;
  grid-template-columns:auto 1fr;
  gap:14px;
  align-items:start;
  padding:14px 16px;
  border-radius:18px;
  background:linear-gradient(180deg, #f9fbfd 0%, #eff4f9 100%);
  border:1px solid rgba(214,224,236,0.95);
}

.enterprise-flow-step span{
  width:34px;
  height:34px;
  border-radius:999px;
  display:grid;
  place-items:center;
  background:#102033;
  color:#fff;
  font-weight:700;
}

.enterprise-table-wrap{
  overflow:auto;
  border-radius:18px;
  border:1px solid rgba(214,224,236,0.95);
}

.enterprise-table{
  width:100%;
  border-collapse:collapse;
  min-width:860px;
  background:#fff;
}

.enterprise-table th,
.enterprise-table td{
  text-align:left;
  padding:14px 16px;
  border-bottom:1px solid rgba(232,238,244,0.95);
}

.enterprise-table th{
  background:#f8fbff;
  color:#5d6f86;
  font-size:.84rem;
  text-transform:uppercase;
  letter-spacing:.14em;
}

.enterprise-cta-card{
  display:grid;
  grid-template-columns:1.2fr auto;
  gap:18px;
  align-items:center;
  padding:24px 26px;
}

.enterprise-cta-card h2{
  margin:6px 0 10px;
  font-size:2rem;
  line-height:1.02;
  letter-spacing:-.03em;
}

@media (max-width: 1100px){
  .enterprise-kpi-grid,
  .enterprise-two-col,
  .enterprise-three-col,
  .enterprise-signal-grid,
  .enterprise-cta-card,
  .enterprise-insight-strip{
    grid-template-columns:1fr;
  }

  .enterprise-tab-head{
    flex-direction:column;
    align-items:start;
  }

  .enterprise-hero-card{
    min-height:220px;
    padding:22px;
  }

  .enterprise-hero-copy h1{
    font-size:2.3rem;
  }

  .enterprise-map-mock{
    min-height:320px;
  }
}


/* ENTERPRISE DASHBOARD V5 */
.enterprise-dashboard.v5{
  display:grid;
  gap:22px;
}

.enterprise-hero-card-v5{
  position:relative;
  overflow:hidden;
  border-radius:28px;
  padding:28px;
  min-height:260px;
  display:flex;
  align-items:center;
  background:
    linear-gradient(90deg, rgba(18,22,28,.78) 0%, rgba(18,22,28,.34) 45%, rgba(18,22,28,.12) 100%),
    url('https://images.unsplash.com/photo-1519996521430-85f6cb5b7e20?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
  color:#fff;
}

.enterprise-hero-copy{
  max-width:760px;
  position:relative;
  z-index:2;
}

.enterprise-hero-copy h1{
  margin:0 0 12px;
  font-size:clamp(2.2rem, 4vw, 4rem);
  line-height:.96;
  letter-spacing:-.04em;
  color:#fff;
}

.enterprise-subcopy{
  max-width:660px;
  margin:0;
  font-size:1.1rem;
  line-height:1.45;
  color:rgba(255,255,255,.92);
}

.enterprise-cta-row,
.enterprise-cta-actions{
  display:flex;
  flex-wrap:wrap;
  gap:12px;
  margin-top:22px;
}

.enterprise-kpi-grid{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:16px;
}

.enterprise-kpi-card{
  padding:20px 22px;
}

.enterprise-kpi-value{
  margin:0;
  font-size:2rem;
  line-height:1;
  font-weight:700;
  color:#102033;
}

.enterprise-kpi-label{
  margin:8px 0 0;
  color:#5c708a;
  font-weight:600;
}

.enterprise-workspace-shell{
  padding:20px;
}

.enterprise-control-row{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:14px;
  margin-bottom:16px;
}

.enterprise-select-group{
  display:grid;
  gap:8px;
}

.enterprise-select-group label{
  font-size:.78rem;
  text-transform:uppercase;
  letter-spacing:.16em;
  font-weight:700;
  color:#6b7d93;
}

.enterprise-select-group select{
  width:100%;
  border-radius:14px;
  border:1px solid rgba(214,224,236,0.95);
  background:#fff;
  padding:12px 14px;
  color:#102033;
  font:600 15px/1 Inter, Arial, sans-serif;
}

.enterprise-tab-row{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  margin-bottom:18px;
}

.enterprise-tab{
  appearance:none;
  border:1px solid rgba(214,224,236,0.95);
  background:#fff;
  color:#102033;
  border-radius:999px;
  padding:10px 16px;
  font-weight:600;
  cursor:pointer;
}

.enterprise-tab.active{
  background:#102033;
  color:#fff;
  border-color:#102033;
}

.enterprise-tab-head{
  display:flex;
  justify-content:space-between;
  gap:16px;
  align-items:end;
  margin-bottom:16px;
}

.enterprise-panel-stack{
  display:grid;
  gap:18px;
}

.enterprise-two-col{
  display:grid;
  grid-template-columns:1.1fr .9fr;
  gap:18px;
}

.enterprise-three-col{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:18px;
}

.enterprise-panel{
  padding:22px;
}

.enterprise-panel-head{
  margin-bottom:18px;
}

.enterprise-panel-head h3,
.enterprise-panel h3{
  margin:6px 0 0;
  color:#102033;
}

.enterprise-status-rail{
  display:grid;
  gap:12px;
  margin-top:16px;
}

.enterprise-status-rail span{
  padding:12px 14px;
  border-radius:14px;
  background:#f7fafc;
  border:1px solid rgba(214,224,236,0.95);
  color:#5d6f86;
  font-weight:600;
}

.enterprise-status-rail span.done{
  background:linear-gradient(180deg, #f8fbff 0%, #eef4fb 100%);
  color:#21405f;
}

.enterprise-status-rail span.active{
  background:linear-gradient(180deg, #fffaf2 0%, #fff3dd 100%);
  color:#8a5a13;
}

.enterprise-watch-chips{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  margin-top:14px;
}

.enterprise-watch-chips span{
  padding:10px 14px;
  border-radius:999px;
  background:linear-gradient(180deg, #fffaf2 0%, #fff3dd 100%);
  border:1px solid rgba(214,224,236,0.95);
  color:#102033;
  font-weight:600;
}

.enterprise-action-list,
.enterprise-alert-stack{
  display:grid;
  gap:12px;
}

.enterprise-action-item{
  display:grid;
  grid-template-columns:auto 1fr;
  gap:12px;
  align-items:start;
  padding:14px 16px;
  border-radius:16px;
  background:#f9fbfd;
  border:1px solid rgba(214,224,236,0.95);
}

.enterprise-action-item span{
  width:30px;
  height:30px;
  border-radius:999px;
  display:grid;
  place-items:center;
  background:#102033;
  color:#fff;
  font-weight:700;
}

.enterprise-action-item p{
  margin:2px 0 0;
  color:#22374d;
  font-weight:600;
}

.enterprise-alert-card{
  padding:16px;
  border-radius:18px;
  background:linear-gradient(180deg, #fffaf2 0%, #fff 100%);
  border:1px solid rgba(214,224,236,0.95);
}

.enterprise-alert-top{
  display:flex;
  justify-content:space-between;
  gap:12px;
  align-items:center;
  margin-bottom:8px;
}

.enterprise-alert-top strong{
  color:#102033;
}

.enterprise-alert-top span{
  padding:6px 10px;
  border-radius:999px;
  background:#102033;
  color:#fff;
  font-size:.78rem;
  font-weight:700;
}

.enterprise-score-card{
  text-align:left;
}

.enterprise-score-value{
  font-size:3rem;
  line-height:1;
  font-weight:700;
  color:#102033;
  margin:8px 0;
}

.enterprise-score-label{
  margin:0 0 8px;
  color:#5d6f86;
  font-weight:600;
}

.enterprise-map-mock{
  position:relative;
  min-height:360px;
  border-radius:24px;
  overflow:hidden;
  border:1px solid rgba(214,224,236,0.95);
  background:
    radial-gradient(circle at 20% 20%, rgba(255,194,92,.22), transparent 18%),
    radial-gradient(circle at 72% 26%, rgba(236,115,87,.20), transparent 20%),
    radial-gradient(circle at 66% 70%, rgba(49,125,255,.14), transparent 18%),
    linear-gradient(180deg, #f7fbff 0%, #edf3f9 100%);
}

.enterprise-map-dot{
  position:absolute;
  width:18px;
  height:18px;
  border-radius:50%;
  background:#d28a2f;
  box-shadow:0 0 0 8px rgba(210,138,47,.14);
}

.enterprise-map-dot.dot-a{ top:22%; left:26%; }
.enterprise-map-dot.dot-b{ top:38%; left:64%; }
.enterprise-map-dot.dot-c{ top:62%; left:44%; }
.enterprise-map-dot.dot-d{ top:71%; left:76%; }

.enterprise-map-ring{
  position:absolute;
  border-radius:999px;
  border:2px dashed rgba(92,112,138,.28);
}

.enterprise-map-ring.ring-a{ inset:18% 18% 42% 24%; }
.enterprise-map-ring.ring-b{ inset:36% 28% 18% 38%; }
.enterprise-map-ring.ring-c{ inset:16% 40% 46% 10%; }

.enterprise-map-label{
  position:absolute;
  padding:8px 10px;
  border-radius:999px;
  background:rgba(255,255,255,.92);
  border:1px solid rgba(214,224,236,0.95);
  color:#213448;
  font-size:.84rem;
  font-weight:600;
}

.enterprise-map-label.label-a{ top:18%; left:10%; }
.enterprise-map-label.label-b{ top:32%; right:10%; }
.enterprise-map-label.label-c{ bottom:22%; left:22%; }

.enterprise-watchlist-table{
  display:grid;
  gap:12px;
}

.enterprise-watchlist-row{
  display:grid;
  grid-template-columns:1.3fr .8fr .8fr .8fr;
  gap:12px;
  padding:14px 16px;
  border-radius:16px;
  border:1px solid rgba(214,224,236,0.95);
  background:#f9fbfd;
}

.enterprise-watchlist-row div{
  display:grid;
  gap:4px;
}

.enterprise-watchlist-row p,
.enterprise-watchlist-row span{
  margin:0;
  color:#6a7c92;
  font-size:.85rem;
}

.enterprise-watchlist-row strong{
  color:#102033;
}

.enterprise-table-wrap{
  overflow:auto;
  border-radius:18px;
  border:1px solid rgba(214,224,236,0.95);
}

.enterprise-table{
  width:100%;
  border-collapse:collapse;
  min-width:760px;
  background:#fff;
}

.enterprise-table th,
.enterprise-table td{
  text-align:left;
  padding:14px 16px;
  border-bottom:1px solid rgba(232,238,244,0.95);
}

.enterprise-table th{
  background:#f8fbff;
  color:#5d6f86;
  font-size:.84rem;
  text-transform:uppercase;
  letter-spacing:.14em;
}

.enterprise-cta-card{
  display:grid;
  grid-template-columns:1.2fr auto;
  gap:18px;
  align-items:center;
  padding:24px 26px;
}

.enterprise-cta-card h2{
  margin:6px 0 10px;
  font-size:2rem;
  line-height:1.02;
  letter-spacing:-.03em;
}

@media (max-width: 1100px){
  .enterprise-kpi-grid,
  .enterprise-control-row,
  .enterprise-two-col,
  .enterprise-three-col,
  .enterprise-cta-card{
    grid-template-columns:1fr;
  }

  .enterprise-tab-head{
    flex-direction:column;
    align-items:start;
  }

  .enterprise-watchlist-row{
    grid-template-columns:1fr 1fr;
  }

  .enterprise-hero-card-v5{
    min-height:220px;
    padding:22px;
  }

  .enterprise-hero-copy h1{
    font-size:2.3rem;
  }
}


/* ENTERPRISE DASHBOARD V6 */
.enterprise-dashboard.v6{
  display:grid;
  gap:22px;
}

.enterprise-demo-topbar{
  display:flex;
  justify-content:space-between;
  gap:18px;
  align-items:center;
  padding:16px 18px;
}

.enterprise-demo-id{
  display:flex;
  gap:14px;
  align-items:center;
}

.enterprise-demo-id strong{
  color:#102033;
  display:block;
}

.enterprise-demo-id p,
.enterprise-demo-meta{
  margin:0;
  color:#607288;
  font-size:.95rem;
}

.enterprise-demo-badge{
  padding:8px 12px;
  border-radius:999px;
  background:linear-gradient(180deg, #fffaf2 0%, #fff3dd 100%);
  border:1px solid rgba(214,224,236,0.95);
  color:#8a5a13;
  font-weight:700;
  font-size:.82rem;
  letter-spacing:.08em;
  text-transform:uppercase;
}

.enterprise-demo-meta{
  display:flex;
  flex-wrap:wrap;
  gap:12px;
}

.enterprise-hero-card-v6{
  position:relative;
  overflow:hidden;
  border-radius:28px;
  padding:28px;
  min-height:280px;
  display:grid;
  grid-template-columns:1.1fr .9fr;
  gap:18px;
  align-items:center;
  background:
    linear-gradient(90deg, rgba(18,22,28,.80) 0%, rgba(18,22,28,.36) 45%, rgba(18,22,28,.14) 100%),
    url('https://images.unsplash.com/photo-1519996521430-85f6cb5b7e20?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
  color:#fff;
}

.enterprise-hero-copy{
  max-width:760px;
  position:relative;
  z-index:2;
}

.enterprise-hero-copy h1{
  margin:0 0 12px;
  font-size:clamp(2.2rem, 4vw, 4rem);
  line-height:.96;
  letter-spacing:-.04em;
  color:#fff;
}

.enterprise-subcopy{
  max-width:660px;
  margin:0;
  font-size:1.1rem;
  line-height:1.45;
  color:rgba(255,255,255,.92);
}

.enterprise-cta-row,
.enterprise-cta-actions{
  display:flex;
  flex-wrap:wrap;
  gap:12px;
  margin-top:22px;
}

.enterprise-demo-rail{
  display:grid;
  gap:12px;
  position:relative;
  z-index:2;
}

.enterprise-demo-rail-card{
  padding:16px 18px;
  border-radius:18px;
  background:rgba(255,255,255,.90);
  border:1px solid rgba(214,224,236,0.95);
  color:#102033;
  box-shadow:0 8px 20px rgba(16,32,51,.08);
}

.enterprise-demo-rail-card span{
  display:block;
  margin-bottom:6px;
  font-size:.78rem;
  text-transform:uppercase;
  letter-spacing:.14em;
  color:#6c7d93;
  font-weight:700;
}

.enterprise-demo-rail-card strong{
  font-size:1.02rem;
  line-height:1.2;
}

.enterprise-kpi-grid{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:16px;
}

.enterprise-kpi-card{
  padding:20px 22px;
}

.enterprise-kpi-value{
  margin:0;
  font-size:2rem;
  line-height:1;
  font-weight:700;
  color:#102033;
}

.enterprise-kpi-label{
  margin:8px 0 0;
  color:#5c708a;
  font-weight:600;
}

.enterprise-workspace-shell{
  padding:20px;
}

.enterprise-control-row{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:14px;
  margin-bottom:16px;
}

.enterprise-select-group{
  display:grid;
  gap:8px;
}

.enterprise-select-group label{
  font-size:.78rem;
  text-transform:uppercase;
  letter-spacing:.16em;
  font-weight:700;
  color:#6b7d93;
}

.enterprise-select-group select{
  width:100%;
  border-radius:14px;
  border:1px solid rgba(214,224,236,0.95);
  background:#fff;
  padding:12px 14px;
  color:#102033;
  font:600 15px/1 Inter, Arial, sans-serif;
}

.enterprise-tab-row{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  margin-bottom:18px;
}

.enterprise-tab{
  appearance:none;
  border:1px solid rgba(214,224,236,0.95);
  background:#fff;
  color:#102033;
  border-radius:999px;
  padding:10px 16px;
  font-weight:600;
  cursor:pointer;
}

.enterprise-tab.active{
  background:#102033;
  color:#fff;
  border-color:#102033;
}

.enterprise-tab-head{
  display:flex;
  justify-content:space-between;
  gap:16px;
  align-items:end;
  margin-bottom:16px;
}

.enterprise-panel-stack{
  display:grid;
  gap:18px;
}

.enterprise-two-col{
  display:grid;
  grid-template-columns:1.1fr .9fr;
  gap:18px;
}

.enterprise-three-col{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:18px;
}

.enterprise-panel{
  padding:22px;
}

.enterprise-panel-head{
  margin-bottom:18px;
}

.enterprise-panel-head h3,
.enterprise-panel h3{
  margin:6px 0 0;
  color:#102033;
}

.enterprise-status-rail{
  display:grid;
  gap:12px;
  margin-top:16px;
}

.enterprise-status-rail span{
  padding:12px 14px;
  border-radius:14px;
  background:#f7fafc;
  border:1px solid rgba(214,224,236,0.95);
  color:#5d6f86;
  font-weight:600;
}

.enterprise-status-rail span.done{
  background:linear-gradient(180deg, #f8fbff 0%, #eef4fb 100%);
  color:#21405f;
}

.enterprise-status-rail span.active{
  background:linear-gradient(180deg, #fffaf2 0%, #fff3dd 100%);
  color:#8a5a13;
}

.enterprise-action-list,
.enterprise-alert-stack{
  display:grid;
  gap:12px;
}

.enterprise-action-item{
  display:grid;
  grid-template-columns:auto 1fr;
  gap:12px;
  align-items:start;
  padding:14px 16px;
  border-radius:16px;
  background:#f9fbfd;
  border:1px solid rgba(214,224,236,0.95);
}

.enterprise-action-item span{
  width:30px;
  height:30px;
  border-radius:999px;
  display:grid;
  place-items:center;
  background:#102033;
  color:#fff;
  font-weight:700;
}

.enterprise-action-item p{
  margin:2px 0 0;
  color:#22374d;
  font-weight:600;
}

.enterprise-alert-card{
  padding:16px;
  border-radius:18px;
  background:linear-gradient(180deg, #fffaf2 0%, #fff 100%);
  border:1px solid rgba(214,224,236,0.95);
}

.enterprise-alert-top{
  display:flex;
  justify-content:space-between;
  gap:12px;
  align-items:center;
  margin-bottom:8px;
}

.enterprise-alert-top strong{
  color:#102033;
}

.enterprise-alert-top span{
  padding:6px 10px;
  border-radius:999px;
  background:#102033;
  color:#fff;
  font-size:.78rem;
  font-weight:700;
}

.enterprise-score-card{
  text-align:left;
}

.enterprise-score-value{
  font-size:3rem;
  line-height:1;
  font-weight:700;
  color:#102033;
  margin:8px 0;
}

.enterprise-score-label{
  margin:0 0 8px;
  color:#5d6f86;
  font-weight:600;
}

.enterprise-map-mock{
  position:relative;
  min-height:360px;
  border-radius:24px;
  overflow:hidden;
  border:1px solid rgba(214,224,236,0.95);
  background:
    radial-gradient(circle at 20% 20%, rgba(255,194,92,.22), transparent 18%),
    radial-gradient(circle at 72% 26%, rgba(236,115,87,.20), transparent 20%),
    radial-gradient(circle at 66% 70%, rgba(49,125,255,.14), transparent 18%),
    linear-gradient(180deg, #f7fbff 0%, #edf3f9 100%);
}

.enterprise-map-dot{
  position:absolute;
  width:18px;
  height:18px;
  border-radius:50%;
  background:#d28a2f;
  box-shadow:0 0 0 8px rgba(210,138,47,.14);
}

.enterprise-map-dot.dot-a{ top:22%; left:26%; }
.enterprise-map-dot.dot-b{ top:38%; left:64%; }
.enterprise-map-dot.dot-c{ top:62%; left:44%; }
.enterprise-map-dot.dot-d{ top:71%; left:76%; }

.enterprise-map-ring{
  position:absolute;
  border-radius:999px;
  border:2px dashed rgba(92,112,138,.28);
}

.enterprise-map-ring.ring-a{ inset:18% 18% 42% 24%; }
.enterprise-map-ring.ring-b{ inset:36% 28% 18% 38%; }
.enterprise-map-ring.ring-c{ inset:16% 40% 46% 10%; }

.enterprise-map-label{
  position:absolute;
  padding:8px 10px;
  border-radius:999px;
  background:rgba(255,255,255,.92);
  border:1px solid rgba(214,224,236,0.95);
  color:#213448;
  font-size:.84rem;
  font-weight:600;
}

.enterprise-map-label.label-a{ top:18%; left:10%; }
.enterprise-map-label.label-b{ top:32%; right:10%; }
.enterprise-map-label.label-c{ bottom:22%; left:22%; }

.enterprise-watchlist-table{
  display:grid;
  gap:12px;
}

.enterprise-watchlist-row{
  display:grid;
  grid-template-columns:1.3fr .8fr .8fr .8fr;
  gap:12px;
  padding:14px 16px;
  border-radius:16px;
  border:1px solid rgba(214,224,236,0.95);
  background:#f9fbfd;
}

.enterprise-watchlist-row div{
  display:grid;
  gap:4px;
}

.enterprise-watchlist-row p,
.enterprise-watchlist-row span{
  margin:0;
  color:#6a7c92;
  font-size:.85rem;
}

.enterprise-watchlist-row strong{
  color:#102033;
}

.enterprise-table-wrap{
  overflow:auto;
  border-radius:18px;
  border:1px solid rgba(214,224,236,0.95);
}

.enterprise-table{
  width:100%;
  border-collapse:collapse;
  min-width:760px;
  background:#fff;
}

.enterprise-table th,
.enterprise-table td{
  text-align:left;
  padding:14px 16px;
  border-bottom:1px solid rgba(232,238,244,0.95);
}

.enterprise-table th{
  background:#f8fbff;
  color:#5d6f86;
  font-size:.84rem;
  text-transform:uppercase;
  letter-spacing:.14em;
}

.enterprise-cta-card{
  display:grid;
  grid-template-columns:1.2fr auto;
  gap:18px;
  align-items:center;
  padding:24px 26px;
}

.enterprise-cta-card h2{
  margin:6px 0 10px;
  font-size:2rem;
  line-height:1.02;
  letter-spacing:-.03em;
}

@media (max-width: 1100px){
  .enterprise-demo-topbar,
  .enterprise-kpi-grid,
  .enterprise-control-row,
  .enterprise-two-col,
  .enterprise-three-col,
  .enterprise-cta-card,
  .enterprise-hero-card-v6{
    grid-template-columns:1fr;
    flex-direction:column;
    align-items:start;
  }

  .enterprise-tab-head{
    flex-direction:column;
    align-items:start;
  }

  .enterprise-watchlist-row{
    grid-template-columns:1fr 1fr;
  }

  .enterprise-hero-card-v6{
    min-height:220px;
    padding:22px;
    display:grid;
  }

  .enterprise-hero-copy h1{
    font-size:2.3rem;
  }
}


